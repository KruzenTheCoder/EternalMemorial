# Prisma reads DATABASE_URL from prisma/schema.prisma — keep this as your primary DB URL.
# Use the "Transaction pooler" URI from Supabase (port 6543) for serverless/Vercel, or direct DB for local dev.

# Transaction pooler (recommended for Prisma on Vercel / Next.js):
# Username MUST be postgres.<project-ref> (not just "postgres") or you get "Tenant or user not found".
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (works well for local dev; user is "postgres"):
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Optional: only if you need a second alias — do not duplicate a broken pooler URL here while DATABASE_URL is correct
# SUPABASE_DATABASE_URL=""

# Optional: migrations when using pooler as DATABASE_URL (Prisma migrate)
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

NEXTAUTH_SECRET="your-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (password reset links). Falls back to NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (Resend). Without RESEND_API_KEY, dev logs the message and skips send.
RESEND_API_KEY=""
EMAIL_FROM="Eternal Memory <onboarding@resend.dev>"

# Bootstrap user for demo admin login (optional)
# ADMIN_EMAIL="admin@example.com"
# ADMIN_NAME="Admin"

LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL="wss://your-livekit-url"

UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
